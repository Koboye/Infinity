# Firebase Client (Public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin (Server-only, never NEXT_PUBLIC_)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini (used by /api/ai/caption and /api/ai/captions — image & video AI captions)
GEMINI_API_KEY=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Flutterwave (real-money payments: donations AND coin top-ups).
# FLW_PUBLIC_KEY is sent to the client (safe). FLW_SECRET_KEY and
# FLW_WEBHOOK_SECRET_HASH are server-only — never expose them.
# Get these from the Flutterwave dashboard > Settings > API Keys, and set
# FLW_WEBHOOK_SECRET_HASH to match the "Secret Hash" you configure under
# Settings > Webhooks (used to point Flutterwave at /api/donations/webhook
# and /api/wallet/topup/webhook).
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_WEBHOOK_SECRET_HASH=

# OTP hashing secret (server-only) — set a long random value in production.
# Falls back to a dev-only default if unset, which is NOT safe for production.
OTP_HASH_SECRET=

# EmailJS private key (server-only, from EmailJS dashboard > Account > API Keys).
# REQUIRED for send-otp to work from this Next.js server route. EmailJS blocks
# API calls that don't come from a verified browser unless this "accessToken"
# is supplied — without it every send returns 403 and users see
# "Failed to send verification email" on sign up.
EMAILJS_PRIVATE_KEY=
