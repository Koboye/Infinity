rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;

      allow update: if request.auth != null && (
        (request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['coins', 'walletBalance']))
        || (request.auth.uid != userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers'])
          && (
            (!resource.data.followers.hasAny([request.auth.uid])
              && request.resource.data.followers.hasAll(resource.data.followers)
              && request.resource.data.followers.hasAny([request.auth.uid])
              && request.resource.data.followers.size() == resource.data.followers.size() + 1)
            || (resource.data.followers.hasAny([request.auth.uid])
              && resource.data.followers.hasAll(request.resource.data.followers)
              && !request.resource.data.followers.hasAny([request.auth.uid])
              && request.resource.data.followers.size() == resource.data.followers.size() - 1)
          )
        )
      );
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/private/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /videos/{videoId} {
      allow read: if request.auth != null;
      allow create: if false;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likes', 'likedBy', 'views', 'viewedBy', 'shares', 'comments', 'savedBy', 'saves', 'poll'])
        || (request.auth.token.admin == true
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['moderationStatus', 'moderatedAt', 'moderatedBy']))
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || request.auth.token.admin == true
      );
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.toUserId;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.toUserId;
    }

    match /conversations/{conversationId} {
      allow read: if request.auth != null && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if request.auth != null && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if request.auth != null && resource.data.participants.hasAny([request.auth.uid]);
    }

    match /messages/{conversationId}/msgs/{msgId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid]);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.from &&
        get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid]);
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.from ||
        (get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid])
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reactions']))
      );
    }

    match /stories/{storyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /calls/{callId} {
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.callerId ||
        request.auth.uid == resource.data.calleeId
      );
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.calleeId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.callerId;

      match /callerCandidates/{candidateId} {
        allow read, create, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId ||
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.calleeId
        );
      }
      match /calleeCandidates/{candidateId} {
        allow read, create, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId ||
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.calleeId
        );
      }
    }

    match /groups/{groupId} {
      allow read, update: if request.auth != null && resource.data.members.hasAny([request.auth.uid]);
      allow create: if request.auth != null && request.resource.data.members.hasAny([request.auth.uid]);
      allow delete: if request.auth != null && request.auth.uid == resource.data.admin;

      match /msgs/{msgId} {
        allow read: if request.auth != null &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.senderId &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
        // Needed so Leave Group (as last member) and Delete Group (admin) can clear
        // the thread's messages before removing the group doc itself.
        allow delete: if request.auth != null &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
      }

      // Group call signaling (state doc + participants/signals subcollections) — any
      // member can read/write, same trust boundary as the group itself. Covers
      // groups/{groupId}/call/state, .../call/state/participants/{uid}, and
      // .../call/state/signals/{pairId} in one recursive rule.
      match /call/{document=**} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
      }
    }

    match /saves/{saveId} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if false;
    }

    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /reports/{reportId} {
      allow create: if request.auth != null && (
        request.resource.data.reportedBy == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
      allow read, delete: if request.auth != null && request.auth.token.admin == true;
    }

    match /liveStreams/{liveId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.streamerId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.streamerId
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewers'])
      );

      match /viewers/{viewerId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == viewerId;
        allow update, delete: if request.auth != null && (
          request.auth.uid == viewerId ||
          request.auth.uid == get(/databases/$(database)/documents/liveStreams/$(liveId)).data.streamerId
        );

        match /hostCandidates/{candidateId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null &&
            request.auth.uid == get(/databases/$(database)/documents/liveStreams/$(liveId)).data.streamerId;
        }
        match /viewerCandidates/{candidateId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null && request.auth.uid == viewerId;
        }
      }
    }
    match /liveMessages/{msgId} {
      allow read, create: if request.auth != null;
    }

    match /presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /typing/{conversationId} {
      allow read, write: if request.auth != null && conversationId.split('_').hasAny([request.auth.uid]);
    }

    match /transactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if false;
    }

    match /users/{userId}/ledger/{entryId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /otps/{email} {
      allow read, write: if false;
    }

    match /payoutRequests/{requestId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create, update, delete: if false;
    }
  }
}
