rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only read/write their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Videos - public read for approved, write only for authenticated
    match /videos/{videoId} {
      allow read: if resource.data.moderationStatus == 'approved';
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Comments - public read, write if authenticated
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Likes - public read, write if authenticated
    match /likes/{likeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Notifications - users can only read their own
    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if request.auth != null;
    }
    
    // Conversations - only participants can read
    match /conversations/{conversationId} {
      allow read: if request.auth != null && resource.data.participants.hasAny([request.auth.uid]);
      allow write: if request.auth != null;
    }
    
    // Messages - only conversation participants
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Stories - public read, write if authenticated
    match /stories/{storyId} {
      allow read: if resource.data.expiresAt > request.time;
      allow write: if request.auth != null;
    }
  }
}
