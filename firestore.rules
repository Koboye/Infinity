rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Broad read is intentional: there's no backend, so the feed, search, comments and
      // follow lists all read this collection directly from the client. Anything sensitive
      // (phone, birthdate) must NOT be written here — see the /private subcollection below.
      // email is a deliberate, documented exception (see createUserProfile in Infinity.jsx).
      allow read: if request.auth != null;

      allow update: if request.auth != null && (
        // Owner may update their own profile EXCEPT coins/walletBalance — those are now
        // server-authoritative (see /api/wallet + firebase-admin.js) so a client write,
        // even from the owner, can no longer move either field. Client SDK writes to the
        // user doc must not touch them (rider-uid check happens client-side already, but
        // Admin SDK calls from /api/wallet bypass these rules entirely, which is how the
        // real balance changes now happen).
        (request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['coins', 'walletBalance']))
        // Any other authenticated user may ONLY touch the followers array on someone else's
        // doc (this is what makes toggleFollow's second write — to the target user's doc —
        // legal; it was previously rejected outright by the owner-only rule above), and only
        // to add or remove their OWN uid — not arbitrary ids. Follow: new list = old list +
        // exactly [auth.uid] (checked via hasAll + size+1, so nothing else could've been
        // removed in the same write). Unfollow: mirror image, old list ⊇ new list, size-1.
        || (request.auth.uid != userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers'])
          && (
            (!resource.data.followers.hasAny([request.auth.uid])
              && request.resource.data.followers.hasAll(resource.data.followers)
              && request.resource.data.followers.hasAny([request.auth.uid])
              && request.resource.data.followers.size() == resource.data.followers.size() + 1)
            || (resource.data.followers.hasAny([request.auth.uid])
              && resource.data.followers.hasAll(request.resource.data.followers)
              && !request.resource.data.followers.hasAny([request.auth.uid])
              && request.resource.data.followers.size() == resource.data.followers.size() - 1)
          )
        )
      );
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Owner-only contact info (phone, birthdate). Split out of the public /users doc so it
    // can't be read via the broad `allow read` above. email stays on the public doc — see
    // the comment there.
    match /users/{userId}/private/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /videos/{videoId} {
      // moderationStatus is now set by POST /api/videos/create (see that route), which also
      // runs content moderation before anything reaches Firestore.
      allow read: if request.auth != null;
      // Creation goes exclusively through /api/videos/create, which moderates content and
      // sets trusted fields (userId, verified badge, counts) via the Admin SDK — which
      // bypasses these rules entirely. Disabled here so a tampered client can't skip
      // moderation or forge a verified badge by writing straight to Firestore.
      allow create: if false;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId
        // Likes, views, shares, comment counts and saves are written by whoever's viewing
        // the post (toggleLike, toggleSave, the view-count effect, share buttons, comment
        // create/delete), not just the author — scope non-owners to just those fields.
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likes', 'likedBy', 'views', 'shares', 'comments', 'savedBy'])
        // Admins approving/rejecting from the Moderation queue — scoped to just the
        // moderation fields so a moderator can't also rewrite the post's content.
        || (request.auth.token.admin == true
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['moderationStatus', 'moderatedAt', 'moderatedBy']))
      );
      // Owner may delete their own post; anyone holding the admin custom claim (see
      // scripts/set-admin.js) may delete any post from the Moderation screen. Replaces the
      // old hardcoded-email check, which broke the moment the moderator's account changed
      // and couldn't be extended to a second moderator without editing this file.
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || request.auth.token.admin == true
      );
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.toUserId;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.toUserId;
    }

    match /conversations/{conversationId} {
      allow read: if request.auth != null && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if request.auth != null && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if request.auth != null && resource.data.participants.hasAny([request.auth.uid]);
    }

    match /messages/{messageId} {
      allow read: if request.auth != null && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.senderId
        && request.resource.data.participants.hasAny([request.auth.uid]);
    }

    match /stories/{storyId} {
      // The client subscribes to the whole /stories collection (no expiresAt filter in the
      // query itself) and filters expired stories locally. A per-document expiresAt > now
      // condition here can't be satisfied for that kind of list query (Firestore requires the
      // query to already filter on any field a list-read rule compares), so it was silently
      // denying the entire stories feed for every user — not just hiding expired ones.
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // None of the rules below existed before. With no matching rule, Firestore denies by
    // default — so calls, group chat, saved posts, the wallet, live-stream chat and content
    // reporting were all silently broken end-to-end (every read/write rejected) despite the
    // client code for all of them working fine. Added one rule block per collection actually
    // used in Infinity.jsx, matching each collection's real read/write pattern in the code.

    // WebRTC call signaling doc (offer/answer/status) plus its two ICE-candidate
    // subcollections. Only the two call participants may touch any of it.
    match /calls/{callId} {
      // The caller checks for an existing call doc (getDoc) before it has been created, to
      // decide whether it's initiating or answering. When the doc doesn't exist yet,
      // `resource` is null, so referencing resource.data.callerId below would throw and get
      // reported as permission-denied instead of "not found" — allow that read explicitly.
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.callerId ||
        request.auth.uid == resource.data.calleeId
      );
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.calleeId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.callerId;

      match /callerCandidates/{candidateId} {
        allow read, create, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId ||
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.calleeId
        );
      }
      match /calleeCandidates/{candidateId} {
        allow read, create, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId ||
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.calleeId
        );
      }
    }

    // Group chats — access gated on membership, same pattern as /conversations above.
    match /groups/{groupId} {
      allow read, update: if request.auth != null && resource.data.members.hasAny([request.auth.uid]);
      allow create: if request.auth != null && request.resource.data.members.hasAny([request.auth.uid]);

      match /msgs/{msgId} {
        allow read: if request.auth != null &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.senderId &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
      }
    }

    // DEPRECATED: saved posts moved to the videos.savedBy array (see FeedPostCard.toggleSave
    // and SavedPostsPage). This collection is no longer written to by the client; rule kept
    // only so any leftover documents from before the migration can still be read/cleaned up.
    match /saves/{saveId} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if false;
    }

    // WhatsApp-style 24h status/broadcast posts.
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // seenBy is updated by whoever views the status, not just its author.
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // User/content reports. Write-only from the client — reviewed via the Firebase console
    // or Admin SDK (which bypasses these rules), so no client read is granted. Two report
    // flows exist with different "who's reporting" field names (user reports use reportedBy,
    // video reports use userId), so both are accepted.
    // The in-app Moderation screen (Settings, owner-only) additionally needs read+delete —
    // gated the same way as the video-delete exception above, by the owner's email, since
    // there's no admin role field in this schema.
    match /reports/{reportId} {
      allow create: if request.auth != null && (
        request.resource.data.reportedBy == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
      // Was hardcoded to a single support email — broke the moment that account changed
      // and couldn't be extended to a second moderator. Uses the admin custom claim instead,
      // same as videos/{videoId} above (see scripts/set-admin.js).
      allow read, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Live stream sessions + their chat. liveMessages only stores a display name, not a
    // uid, so per-sender write restriction isn't possible without a client-side change;
    // any authenticated user may post/read, same trust level as the rest of live chat.
    match /liveStreams/{liveId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.streamerId;
      // Any authenticated viewer joining/leaving bumps the viewer count on the streamer's
      // doc, so non-owner updates are allowed but scoped to just that field.
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.streamerId
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewers'])
      );

      // WebRTC signaling per viewer (offer/answer) plus each viewer's two ICE-candidate
      // subcollections. No rule existed for any of this, so Firestore default-denied it —
      // that's why joining/hosting a live stream failed outright. The viewer doc id is the
      // viewer's own uid (see viewerDocRef in Infinity.jsx), so it doubles as the ownership
      // check; the streamer also needs read/write access since it writes the offer and
      // listens for every viewer's answer.
      match /viewers/{viewerId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == viewerId;
        allow update, delete: if request.auth != null && (
          request.auth.uid == viewerId ||
          request.auth.uid == get(/databases/$(database)/documents/liveStreams/$(liveId)).data.streamerId
        );

        match /hostCandidates/{candidateId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null &&
            request.auth.uid == get(/databases/$(database)/documents/liveStreams/$(liveId)).data.streamerId;
        }
        match /viewerCandidates/{candidateId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null && request.auth.uid == viewerId;
        }
      }
    }
    match /liveMessages/{msgId} {
      allow read, create: if request.auth != null;
    }

    // DEPRECATED: wallet history now lives in /users/{uid}/ledger (see below), written only
    // by /api/wallet via the Admin SDK. Rule kept read-only so old documents (if any) can
    // still be viewed; create is now denied since the client no longer owns this data.
    match /transactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if false;
    }

    // Wallet ledger — written exclusively by /api/wallet through the Admin SDK, which
    // bypasses these rules. The client may only read its own entries.
    match /users/{userId}/ledger/{entryId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // One-time signup codes. Entirely server-owned (see /api/auth/send-otp and
    // /api/auth/verify-otp, both using the Admin SDK) — no client access at all, since
    // even read access would let someone watch for their own code, defeating the "control
    // of the inbox" proof the code is meant to provide as part of account creation.
    match /otps/{email} {
      allow read, write: if false;
    }

    // Payout requests created server-side by /api/wallet on withdrawal. The owner may read
    // their own requests to check status; only the Admin SDK (a backend payout job) marks
    // them processed, so no client update/delete is granted.
    match /payoutRequests/{requestId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create, update, delete: if false;
    }
  }
}
