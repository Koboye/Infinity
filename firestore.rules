rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Broad read is intentional: there's no backend, so the feed, search, comments and
      // follow lists all read this collection directly from the client. Anything sensitive
      // (phone, birthdate) must NOT be written here — see the /private subcollection below.
      // email is a deliberate, documented exception (see createUserProfile in Infinity.jsx).
      allow read: if request.auth != null;

      allow update: if request.auth != null && (
        // Owner may update any field on their own profile. There's no backend here (see
        // the read comment above), so this necessarily trusts the client for wallet
        // balance changes (WalletPage's top-up/withdraw/convert) and the "Reset account"
        // flow in ProfilePage, which both write coins/walletBalance/followers/following
        // directly to the owner's own doc — the previous version blocked the owner from
        // touching those fields at all, which silently broke all three features (and meant
        // toggleFollow's own-doc "following" write never actually persisted).
        request.auth.uid == userId
        // Any other authenticated user may ONLY touch the followers array on someone else's
        // doc (this is what makes toggleFollow's second write — to the target user's doc —
        // legal; it was previously rejected outright by the owner-only rule above). Note:
        // this doesn't verify the array only gained/lost request.auth.uid specifically, just
        // that no other field changed — a known, low-severity gap (worst case a bad actor
        // pollutes someone's followers array with junk ids, not a data-exposure issue).
        || (request.auth.uid != userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']))
      );
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Owner-only contact info (phone, birthdate). Split out of the public /users doc so it
    // can't be read via the broad `allow read` above. email stays on the public doc — see
    // the comment there.
    match /users/{userId}/private/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /videos/{videoId} {
      // moderationStatus is never written anywhere in the client (no moderation queue is
      // implemented), so gating reads on it meant resource.data.moderationStatus was always
      // undefined — every video was unreadable by anyone except its own author. Match the
      // rest of this ruleset's "no backend, so read is broad" posture instead.
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId
        // Likes, views, shares, comment counts and saves are written by whoever's viewing
        // the post (toggleLike, toggleSave, the view-count effect, share buttons, comment
        // create/delete), not just the author — scope non-owners to just those fields.
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likes', 'likedBy', 'views', 'shares', 'comments', 'savedBy'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.toUserId;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.toUserId;
    }

    match /conversations/{conversationId} {
      allow read: if request.auth != null && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if request.auth != null && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if request.auth != null && resource.data.participants.hasAny([request.auth.uid]);
    }

    match /messages/{messageId} {
      allow read: if request.auth != null && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.senderId
        && request.resource.data.participants.hasAny([request.auth.uid]);
    }

    match /stories/{storyId} {
      // The client subscribes to the whole /stories collection (no expiresAt filter in the
      // query itself) and filters expired stories locally. A per-document expiresAt > now
      // condition here can't be satisfied for that kind of list query (Firestore requires the
      // query to already filter on any field a list-read rule compares), so it was silently
      // denying the entire stories feed for every user — not just hiding expired ones.
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // None of the rules below existed before. With no matching rule, Firestore denies by
    // default — so calls, group chat, saved posts, the wallet, live-stream chat and content
    // reporting were all silently broken end-to-end (every read/write rejected) despite the
    // client code for all of them working fine. Added one rule block per collection actually
    // used in Infinity.jsx, matching each collection's real read/write pattern in the code.

    // WebRTC call signaling doc (offer/answer/status) plus its two ICE-candidate
    // subcollections. Only the two call participants may touch any of it.
    match /calls/{callId} {
      allow read, update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.calleeId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.callerId;

      match /callerCandidates/{candidateId} {
        allow read, create, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId ||
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.calleeId
        );
      }
      match /calleeCandidates/{candidateId} {
        allow read, create, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId ||
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.calleeId
        );
      }
    }

    // Group chats — access gated on membership, same pattern as /conversations above.
    match /groups/{groupId} {
      allow read, update: if request.auth != null && resource.data.members.hasAny([request.auth.uid]);
      allow create: if request.auth != null && request.resource.data.members.hasAny([request.auth.uid]);

      match /msgs/{msgId} {
        allow read: if request.auth != null &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.senderId &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
      }
    }

    // Saved posts. Doc id is `${videoId}_${userId}`, but the rule checks the userId field
    // (set on create) rather than parsing the id, so it doesn't depend on that convention.
    match /saves/{saveId} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // WhatsApp-style 24h status/broadcast posts.
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // seenBy is updated by whoever views the status, not just its author.
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // User/content reports. Write-only from the client — reviewed via the Firebase console
    // or Admin SDK (which bypasses these rules), so no client read is granted. Two report
    // flows exist with different "who's reporting" field names (user reports use reportedBy,
    // video reports use userId), so both are accepted.
    match /reports/{reportId} {
      allow create: if request.auth != null && (
        request.resource.data.reportedBy == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
    }

    // Live stream sessions + their chat. liveMessages only stores a display name, not a
    // uid, so per-sender write restriction isn't possible without a client-side change;
    // any authenticated user may post/read, same trust level as the rest of live chat.
    match /liveStreams/{liveId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.streamerId;
      // Any authenticated viewer joining/leaving bumps the viewer count on the streamer's
      // doc, so non-owner updates are allowed but scoped to just that field.
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.streamerId
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewers'])
      );
    }
    match /liveMessages/{msgId} {
      allow read, create: if request.auth != null;
    }

    // Wallet ledger (WalletPage top-up/withdraw/convert history).
    match /transactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
